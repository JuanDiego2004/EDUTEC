{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "disableSizeLimit": true,
    "maxNodeModuleJsDepth": 1,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/componentes/*": [
        "./src/componentes/*"
      ],
      "@/funcionalidades/*": [
        "./src/funcionalidades/*"
      ],
      "@/servicios/*": [
        "./src/servicios/*"
      ],
      "@/ganchos/*": [
        "./src/ganchos/*"
      ],
      "@/utilidades/*": [
        "./src/utilidades/*"
      ],
      "@/tipos/*": [
        "./src/tipos/*"
      ],
      "@/configuracion/*": [
        "./src/configuracion/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/supabase"
  ]
}